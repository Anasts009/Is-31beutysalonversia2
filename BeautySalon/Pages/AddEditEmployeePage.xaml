<Page x:Class="BeautySalon.Pages.AddEditEmployeePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Редактирование сотрудника"
      Background="White"
      Width="650"
      Height="550">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Редактирование сотрудника" 
                   FontSize="16" 
                   FontWeight="Bold"
                   Foreground="#FF333333"
                   Margin="0,0,0,10"/>

        <!-- Личные данные -->
        <Border Grid.Row="1" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="5"
                Background="#FAFAFA"
                Padding="8"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" 
                           Grid.ColumnSpan="2"
                           Text="Личные данные"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="#FF666666"
                           Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Имя:" 
                           VerticalAlignment="Center" 
                           FontSize="11"
                           Margin="0,0,5,0"/>
                <TextBox x:Name="FirstnameBox" 
                         Grid.Row="2" Grid.Column="0"
                         Margin="0,0,8,0"
                         Padding="5"
                         Height="26"
                         BorderBrush="#DDDDDD"
                         BorderThickness="1"
                         FontSize="11"/>

                <TextBlock Grid.Row="1" Grid.Column="1" 
                           Text="Фамилия:" 
                           VerticalAlignment="Center" 
                           FontSize="11"
                           Margin="0,0,5,0"/>
                <TextBox x:Name="LastnameBox" 
                         Grid.Row="2" Grid.Column="1"
                         Padding="5"
                         Height="26"
                         BorderBrush="#DDDDDD"
                         BorderThickness="1"
                         FontSize="11"/>
            </Grid>
        </Border>

        <!-- Телефон и Рабочие данные в одной строке -->
        <Border Grid.Row="2" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="5"
                Background="#FAFAFA"
                Padding="8"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" 
                           Grid.ColumnSpan="2"
                           Text="Контактные данные"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="#FF666666"
                           Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Телефон:" 
                           VerticalAlignment="Center" 
                           FontSize="11"
                           Margin="0,0,5,0"/>
                <TextBox x:Name="PhoneBox" 
                         Grid.Row="2" Grid.Column="0"
                         Margin="0,0,8,0"
                         Padding="5"
                         Height="26"
                         BorderBrush="#DDDDDD"
                         BorderThickness="1"
                         FontSize="11"/>

                <TextBlock Grid.Row="1" Grid.Column="1" 
                           Text="Кабинет:" 
                           VerticalAlignment="Center" 
                           FontSize="11"
                           Margin="0,0,5,0"/>
                <ComboBox x:Name="CabinetBox" 
                          Grid.Row="2" Grid.Column="1"
                          Padding="5"
                          Height="26"
                          BorderBrush="#DDDDDD"
                          BorderThickness="1"
                          FontSize="11"
                          DisplayMemberPath="NameCabinet" 
                          SelectedValuePath="CabinetId"/>
            </Grid>
        </Border>

        <!-- Должность и Роль -->
        <Border Grid.Row="3" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="5"
                Background="#FAFAFA"
                Padding="8"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" 
                           Grid.ColumnSpan="2"
                           Text="Рабочие данные"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="#FF666666"
                           Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Должность:" 
                           VerticalAlignment="Center" 
                           FontSize="11"
                           Margin="0,0,5,0"/>
                <ComboBox x:Name="PostBox" 
                          Grid.Row="2" Grid.Column="0"
                          Margin="0,0,8,0"
                          Padding="5"
                          Height="26"
                          BorderBrush="#DDDDDD"
                          BorderThickness="1"
                          FontSize="11"
                          DisplayMemberPath="PostName" 
                          SelectedValuePath="PostId"/>

                <TextBlock Grid.Row="1" Grid.Column="1" 
                           Text="Роль:" 
                           VerticalAlignment="Center" 
                           FontSize="11"
                           Margin="0,0,5,0"/>
                <ComboBox x:Name="RoleBox" 
                          Grid.Row="2" Grid.Column="1"
                          Padding="5"
                          Height="26"
                          BorderBrush="#DDDDDD"
                          BorderThickness="1"
                          FontSize="11"
                          DisplayMemberPath="RoleName" 
                          SelectedValuePath="RoleId"/>
            </Grid>
        </Border>

        <!-- Учётные данные и Блокировка -->
        <Border Grid.Row="4" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="5"
                Background="#FAFAFA"
                Padding="8"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" 
                           Grid.ColumnSpan="2"
                           Text="Учётные данные"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="#FF666666"
                           Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Логин:" 
                           VerticalAlignment="Center" 
                           FontSize="11"
                           Margin="0,0,5,0"/>
                <TextBox x:Name="LoginBox" 
                         Grid.Row="2" Grid.Column="0"
                         Margin="0,3,8,29"
                         Padding="5"
                         Height="26"
                         BorderBrush="#DDDDDD"
                         BorderThickness="1"
                         FontSize="11"/>

                <TextBlock Grid.Row="1" Grid.Column="1" 
                           Text="Пароль:" 
                           VerticalAlignment="Center" 
                           FontSize="11"
                           Margin="0,0,5,0"/>
                <PasswordBox x:Name="PasswordBox" 
                             Grid.Row="2"
                             Padding="5"
                             Height="26"
                             BorderBrush="#DDDDDD"
                             BorderThickness="1"
                             FontSize="11" Grid.ColumnSpan="2" Margin="302,3,2,29"/>

                <CheckBox x:Name="BlockCheckBox" 
                          Grid.Row="2" Grid.ColumnSpan="2"
                          Content="Заблокирован"
                          VerticalAlignment="Top"
                          Margin="-2,34,2,0"
                          FontSize="11"/>
            </Grid>
        </Border>

        <!-- Блок ошибок -->
        <Border Grid.Row="5" 
                Background="#FFF9E6" 
                BorderBrush="#FFE6B3" 
                BorderThickness="1"
                CornerRadius="4"
                Padding="6"
                Margin="0,0,0,8"
                Visibility="Collapsed"
                x:Name="ErrorBorder">
            <TextBlock x:Name="ErrorText" 
                       Foreground="#D32F2F"
                       TextWrapping="Wrap"
                       FontSize="10"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,33,0,-30">
            <Button x:Name="CancelButton" 
                    Content="Отмена"
                    Width="80"
                    Height="30"
                    Margin="0,0,10,0"
                    Background="#E0E0E0"
                    Foreground="#666666"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CancelButton_Click"
                    FontSize="8"/>

            <Button x:Name="SaveButton" 
                    Content="Сохранить"
                    Width="80"
                    Height="30"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SaveButton_Click"
                    FontSize="8"
                    FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Page>