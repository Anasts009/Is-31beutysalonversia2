<Page x:Class="BeautySalon.Pages.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление услугами"
      Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление услугами" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Foreground="#FF333333"
                   Margin="0,0,0,20"/>

        <!-- Панель поиска и сортировки -->
        <Border Grid.Row="1" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1"
                CornerRadius="10"
                Background="#F9F9F9"
                Padding="15"
                Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <TextBox x:Name="SearchBox" 
                         Grid.Row="0"
                         Grid.ColumnSpan="3"
                         Tag="Поиск по названию или описанию..."
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"
                         TextChanged="SearchBox_TextChanged"
                         Padding="10"
                         Margin="0,0,0,10"
                         Background="White"
                         BorderBrush="#DDDDDD"
                         BorderThickness="1"
                         FontSize="14"/>

                <!-- Фильтр по цене -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                    <TextBlock Text="Цена от:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="PriceFromBox" 
                             Width="80" 
                             Padding="5"
                             TextChanged="PriceFilter_TextChanged"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="до:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <TextBox x:Name="PriceToBox" 
                             Width="80" 
                             Padding="5"
                             TextChanged="PriceFilter_TextChanged"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="₽" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                <!-- Сортировка -->
                <ComboBox x:Name="SortBox" 
                          Grid.Row="1" Grid.Column="1"
                          Width="200"
                          Margin="0,0,10,0"
                          Padding="8"
                          Background="White"
                          BorderBrush="#DDDDDD"
                          SelectionChanged="SortBox_SelectionChanged"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="По названию (А-Я)" IsSelected="True"/>
                    <ComboBoxItem Content="По названию (Я-А)"/>
                    <ComboBoxItem Content="По цене (возрастание)"/>
                    <ComboBoxItem Content="По цене (убывание)"/>
                    <ComboBoxItem Content="По времени (возрастание)"/>
                    <ComboBoxItem Content="По времени (убывание)"/>
                </ComboBox>

                <!-- Кнопка добавления -->
                <Button x:Name="AddButton" 
                        Grid.Row="1" Grid.Column="2"
                        Content="+ Добавить услугу"
                        Background="#4CAF50"
                        Foreground="White"
                        Padding="15,8"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="AddButton_Click"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Кнопки быстрой фильтрации -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Все услуги" 
                    Click="QuickFilter_Click"
                    Tag="all"
                    Background="#E0E0E0"
                    Padding="15,5"
                    Margin="0,0,10,0"/>
            <Button Content="До 1000 ₽" 
                    Click="QuickFilter_Click"
                    Tag="cheap"
                    Background="#E0E0E0"
                    Padding="15,5"
                    Margin="0,0,10,0"/>
            <Button Content="От 1000 до 5000 ₽" 
                    Click="QuickFilter_Click"
                    Tag="medium"
                    Background="#E0E0E0"
                    Padding="15,5"
                    Margin="0,0,10,0"/>
            <Button Content="От 5000 ₽" 
                    Click="QuickFilter_Click"
                    Tag="expensive"
                    Background="#E0E0E0"
                    Padding="15,5"
                    Margin="0,0,10,0"/>
            <Button Content="Сбросить фильтры" 
                    Click="ClearFilters_Click"
                    Background="#FF9800"
                    Foreground="White"
                    Padding="15,5"/>
        </StackPanel>

        <!-- Таблица услуг -->
        <DataGrid x:Name="ServicesGrid" 
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  RowHeight="60"
                  Margin="0,0,0,10"
                  AlternatingRowBackground="#F9F9F9"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1"
                  GridLinesVisibility="Horizontal">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" 
                        Binding="{Binding ServiceId}" 
                        Width="50"/>

                <DataGridTextColumn Header="Название услуги" 
                        Binding="{Binding NameServices}" 
                        Width="*"/>

                <DataGridTextColumn Header="Описание" 
                        Binding="{Binding DescriptionService}" 
                        Width="2*" 
                        ElementStyle="{StaticResource WrapTextStyle}"/>

                <DataGridTextColumn Header="Цена (₽)" 
                        Binding="{Binding Price, StringFormat=N0}" 
                        Width="100"/>

                <DataGridTextColumn Header="Время" 
                        Binding="{Binding TimeDisplay}" 
                        Width="100"/>

                <DataGridTemplateColumn Header="Действия" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="✏ Редакт." 
                                        Click="EditButton_Click"
                                        Tag="{Binding ServiceId}"
                                        Background="#FFC107"
                                        Foreground="White"
                                        Padding="5,5"
                                        Margin="0,0,5,0"
                                        Cursor="Hand"
                                        FontSize="8"/>
                                <Button Content="🗑 Удалить" 
                                        Click="DeleteButton_Click"
                                        Tag="{Binding ServiceId}"
                                        Background="#F44336"
                                        Foreground="White"
                                        Padding="5,5"
                                        Cursor="Hand"
                                        FontSize="8"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusText" 
                   Grid.Row="3"
                   VerticalAlignment="Bottom"
                   Foreground="Gray"
                   FontSize="11"
                   Margin="0,5,0,0"/>
    </Grid>
</Page>