<Page x:Class="BeautySalon.Pages.AdminMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Административное меню" 
      Background="#e6e6e6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TextCurrentUser" 
                   FontSize="20" 
                   Foreground="#333333" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   FontWeight="Bold"/>

        <Button Grid.Row="1" 
                HorizontalAlignment="Center" 
                Click="BtnUser_Click" 
                Content="👥 Управление пользователями" 
                x:Name="BtnUser" 
                FontSize="16" 
                Width="400" 
                Height="50"
                Margin="0,10"/>

        <Button Grid.Row="2" 
                HorizontalAlignment="Center" 
                Click="BtnServices_Click" 
                Content="💇 Управление услугами" 
                x:Name="BtnServices" 
                FontSize="16" 
                Width="400" 
                Height="50"
                Margin="0,10"/>

        <Button Grid.Row="3" 
                HorizontalAlignment="Center" 
                Click="BtnRegistrations_Click" 
                Content="📅 Управление записями" 
                x:Name="BtnRegistrations" 
                FontSize="16" 
                Width="400" 
                Height="50"
                Margin="0,10"/>

        <Button Grid.Row="4" 
                HorizontalAlignment="Center" 
                Click="BtnRoom_Click" 
                Content="🏢 Управление кабинетами" 
                x:Name="BtnRoom" 
                FontSize="16" 
                Width="400" 
                Height="50"
                Margin="0,10"/>

        <Button Grid.Row="5" 
                HorizontalAlignment="Center" 
                Click="BtnLogout_Click" 
                Content="🚪 Выход" 
                x:Name="BtnLogout" 
                FontSize="16" 
                Width="200" 
                Height="40"
                Margin="0,20"
                Background="#FF5722"
                Foreground="White"/>
        <Button Grid.Row="0" HorizontalAlignment="Center" x:Name="EmployeesButton" Content="👥Управление сотрудниками" Click="EmployeesButton_Click"  FontSize="16" Width="400" Height="50" Margin="0,10"/>
    </Grid>
</Page>