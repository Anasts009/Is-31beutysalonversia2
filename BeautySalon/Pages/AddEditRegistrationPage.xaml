<Page x:Class="BeautySalon.Pages.AddEditRegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавление записи"
      Background="White"
      Width="650"
      Height="580">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Добавление записи" 
                       FontSize="18" 
                       FontWeight="Bold"
                       Foreground="#FF333333"
                       Margin="0,0,0,12"/>

            <!-- Клиент -->
            <TextBlock Grid.Row="1" Text="Клиент:" Margin="0,0,0,3" FontWeight="SemiBold" FontSize="12"/>
            <ComboBox x:Name="ClientBox" 
                      Grid.Row="2" 
                      Margin="0,0,0,10"
                      Padding="6"
                      Height="30"
                      DisplayMemberPath="FullName"
                      SelectedValuePath="ClientId"
                      FontSize="12"/>

            <!-- Сотрудник -->
            <TextBlock Grid.Row="3" Text="Сотрудник:" Margin="0,0,0,3" FontWeight="SemiBold" FontSize="12"/>
            <ComboBox x:Name="EmployeeBox" 
                      Grid.Row="4" 
                      Margin="0,0,0,10"
                      Padding="6"
                      Height="30"
                      FontSize="12"
                      SelectedValuePath="EmployeeId"
                      DisplayMemberPath="FullName"/>

            <!-- Дата и время -->
            <Grid Grid.Row="5" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Дата:" Margin="0,0,0,3" FontWeight="SemiBold" FontSize="12"/>
                    <DatePicker x:Name="DatePicker" Height="30" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Время:" Margin="0,0,0,3" FontWeight="SemiBold" FontSize="12"/>
                    <TextBox x:Name="TimeBox" 
                             Tag="ЧЧ:ММ"
                             GotFocus="TimeBox_GotFocus"
                             LostFocus="TimeBox_LostFocus"
                             Text="ЧЧ:ММ"
                             Foreground="Gray"
                             Height="30"
                             FontSize="12"
                             Padding="6"/>
                </StackPanel>
            </Grid>

            <!-- Услуги -->
            <TextBlock Grid.Row="6" Text="Услуги:" Margin="0,0,0,3" FontWeight="SemiBold" FontSize="12"/>
            <ListBox x:Name="ServicesList" 
                     Grid.Row="7" 
                     Height="150"
                     SelectionMode="Multiple"
                     Margin="0,0,0,8"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding NameServices}" Width="200" FontSize="12"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" Margin="10,0,0,0" FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Height" Value="28"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Итоговая сумма -->
            <TextBlock x:Name="TotalTextBlock" 
                       Grid.Row="8" 
                       Margin="0,5,0,8"
                       FontSize="13"
                       FontWeight="Bold"
                       Foreground="#FF9800"
                       Text="Итого: 0 ₽"/>

            <!-- Блок ошибок -->
            <Border Grid.Row="9" 
                    Background="#FFF9E6" 
                    BorderBrush="#FFE6B3" 
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6"
                    Margin="0,0,0,10"
                    Visibility="Collapsed"
                    x:Name="ErrorBorder">
                <TextBlock x:Name="ErrorText" 
                           Foreground="#D32F2F"
                           TextWrapping="Wrap"
                           FontSize="11"/>
            </Border>

            <!-- Кнопки -->
            <StackPanel Grid.Row="10" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,5,0,0">
                <Button x:Name="CancelButton" 
                        Content="Отмена"
                        Width="70"
                        Height="38"
                        Margin="0,0,10,0"
                        Background="#E0E0E0"
                        Foreground="#666666"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CancelButton_Click"
                        FontSize="10"/>

                <Button x:Name="SaveButton" 
                        Content="Сохранить"
                        Width="70"
                        Height="38"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SaveButton_Click"
                        FontSize="10"
                        FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>